<Window
    x:Class="DevExpressInspiredControls.Demo.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:DevExpressInspiredControls.Controls;assembly=DevExpressInspiredControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Office 2019 Colorful Control Gallery"
    Width="980"
    Height="760"
    MinWidth="760"
    MinHeight="600"
    Background="{DynamicResource DxWindowBrush}"
    FontFamily="{DynamicResource DxFontFamily}"
    Foreground="{DynamicResource DxTextBrush}"
    mc:Ignorable="d">
    <Window.Resources>
        <Style x:Key="SectionBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="Margin" Value="0,0,0,16" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Background" Value="{DynamicResource DxSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DxBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="2" />
        </Style>
        <Style x:Key="SectionTitleStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="FieldLabelStyle" TargetType="{x:Type Label}">
            <Setter Property="Padding" Value="0,5,12,5" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource DxAccentBrush}">
            <TextBlock
                Margin="24,0"
                VerticalAlignment="Center"
                FontSize="{DynamicResource DxHeaderFontSize}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource DxOnAccentTextBrush}"
                Text="Office 2019 Colorful-inspired controls" />
        </Border>

        <ScrollViewer
            Grid.Row="1"
            Padding="24"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="900">
                <TextBlock
                    Margin="0,0,0,18"
                    Foreground="{DynamicResource DxTextSecondaryBrush}"
                    Text="Dependency-free WPF controls using commands, data binding, validation, keyboard navigation, and UI Automation."
                    TextWrapping="Wrap" />

                <Border Style="{StaticResource SectionBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Buttons" />
                        <WrapPanel>
                            <Button MinWidth="100" Margin="0,0,10,10" AutomationProperties.Name="Standard action" Content="_Standard" />
                            <Button MinWidth="100" Margin="0,0,10,10" AutomationProperties.Name="Default action" Content="_Default" IsDefault="True" />
                            <Button MinWidth="100" Margin="0,0,10,10" AutomationProperties.Name="Disabled action" Content="Disabled" IsEnabled="False" />
                            <Button
                                MinWidth="120"
                                Margin="0,0,10,10"
                                AutomationProperties.HelpText="Runs an ICommand on the view model"
                                Command="{Binding SaveCommand}"
                                Content="_Run command" />
                        </WrapPanel>
                        <TextBlock Foreground="{DynamicResource DxTextSecondaryBrush}" Text="{Binding LastAction}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Text editors" />
                        <Grid Grid.IsSharedSizeScope="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="Labels" />
                                <ColumnDefinition Width="260" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Label Style="{StaticResource FieldLabelStyle}" Content="_Standard:" Target="{Binding ElementName=StandardText}" />
                            <TextBox
                                x:Name="StandardText"
                                Grid.Column="1"
                                Margin="0,0,0,8"
                                AutomationProperties.HelpText="A standard editable text field"
                                Text="Editable value" />
                            <Label Grid.Row="1" Style="{StaticResource FieldLabelStyle}" Content="_Read only:" Target="{Binding ElementName=ReadOnlyText}" />
                            <TextBox x:Name="ReadOnlyText" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" IsReadOnly="True" Text="Read-only value" />
                            <Label Grid.Row="2" Style="{StaticResource FieldLabelStyle}" Content="_Disabled:" Target="{Binding ElementName=DisabledText}" />
                            <TextBox x:Name="DisabledText" Grid.Row="2" Grid.Column="1" IsEnabled="False" Text="Disabled value" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Selection editors" />
                        <Grid Grid.IsSharedSizeScope="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="Labels" />
                                <ColumnDefinition Width="260" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Label Style="{StaticResource FieldLabelStyle}" Content="_Role:" Target="{Binding ElementName=RoleCombo}" />
                            <ComboBox
                                x:Name="RoleCombo"
                                Grid.Column="1"
                                Margin="0,0,0,8"
                                AutomationProperties.HelpText="Select a role"
                                ItemsSource="{Binding Roles}"
                                SelectedItem="{Binding SelectedRole, Mode=TwoWay}" />
                            <Label Grid.Row="1" Style="{StaticResource FieldLabelStyle}" Content="_Editable role:" Target="{Binding ElementName=EditableRoleCombo}" />
                            <ComboBox
                                x:Name="EditableRoleCombo"
                                Grid.Row="1"
                                Grid.Column="1"
                                IsEditable="True"
                                ItemsSource="{Binding Roles}"
                                Text="{Binding SelectedRole, Mode=TwoWay}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Choice controls" />
                        <WrapPanel Margin="0,0,0,10">
                            <CheckBox Margin="0,0,24,0" Content="_Enabled option" IsChecked="{Binding IsFeatureEnabled, Mode=TwoWay}" />
                            <CheckBox Margin="0,0,24,0" Content="Indeterminate" IsChecked="{x:Null}" IsThreeState="True" />
                            <CheckBox Content="Disabled" IsEnabled="False" />
                        </WrapPanel>
                        <WrapPanel Margin="0,0,0,10">
                            <RadioButton Margin="0,0,24,0" Content="_Choice one" GroupName="GalleryChoice" IsChecked="True" />
                            <RadioButton Margin="0,0,24,0" Content="Choice _two" GroupName="GalleryChoice" />
                            <RadioButton Content="Disabled" GroupName="GalleryChoice" IsEnabled="False" />
                        </WrapPanel>
                        <WrapPanel>
                            <controls:ToggleSwitch
                                Margin="0,0,28,0"
                                AutomationProperties.Name="Feature enabled"
                                Content="Feature"
                                IsChecked="{Binding IsFeatureEnabled, Mode=TwoWay}" />
                            <controls:ToggleSwitch
                                AutomationProperties.Name="Unavailable feature"
                                Content="Disabled"
                                IsChecked="True"
                                IsEnabled="False" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="MVVM validation" />
                        <TextBlock
                            Margin="0,0,0,10"
                            Foreground="{DynamicResource DxTextSecondaryBrush}"
                            Text="Enter at least three characters. The view model implements INotifyDataErrorInfo."
                            TextWrapping="Wrap" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="260" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Style="{StaticResource FieldLabelStyle}" Content="_Display name:" Target="{Binding ElementName=ValidatedName}" />
                            <TextBox
                                x:Name="ValidatedName"
                                Grid.Column="1"
                                AutomationProperties.HelpText="Required; at least three characters"
                                Text="{Binding DisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />
                            <TextBlock
                                Grid.Column="2"
                                Margin="10,5,0,0"
                                Foreground="{DynamicResource DxErrorBrush}"
                                Text="{Binding ElementName=ValidatedName, Path=(Validation.Errors)[0].ErrorContent}" />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
