<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="DxToolBarButtonBaseStyle" TargetType="{x:Type ButtonBase}">
        <Setter Property="Background" Value="{DynamicResource DxTransparentBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource DxTransparentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource DxTextBrush}" />
        <Setter Property="FocusVisualStyle" Value="{DynamicResource DxFocusVisualStyle}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="MinHeight" Value="26" />
        <Setter Property="Padding" Value="7,3" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ButtonBase}">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{DynamicResource DxCornerRadius}">
                        <ContentPresenter
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            RecognizesAccessKey="True" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource DxSurfaceHoverBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource DxAccentBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource DxSurfacePressedBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource DxAccentPressedBrush}" />
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource DxAccentBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="{DynamicResource DxDisabledBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource DxTextDisabledBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style
        x:Key="DxToolBarButtonStyle"
        BasedOn="{StaticResource DxToolBarButtonBaseStyle}"
        TargetType="{x:Type Button}" />

    <Style
        x:Key="DxToolBarToggleButtonStyle"
        BasedOn="{StaticResource DxToolBarButtonBaseStyle}"
        TargetType="{x:Type ToggleButton}">
        <Style.Triggers>
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="Background" Value="{DynamicResource DxAccentBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource DxAccentBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource DxOnAccentTextBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style
        x:Key="DxToolBarRepeatButtonStyle"
        BasedOn="{StaticResource DxToolBarButtonBaseStyle}"
        TargetType="{x:Type RepeatButton}" />

    <Style x:Key="DxToolBarSeparatorStyle" TargetType="{x:Type Separator}">
        <Setter Property="Margin" Value="5,3" />
        <Setter Property="Width" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Separator}">
                    <Border Background="{DynamicResource DxBorderBrush}" SnapsToDevicePixels="True" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style
        x:Key="{x:Static ToolBar.ButtonStyleKey}"
        BasedOn="{StaticResource DxToolBarButtonStyle}"
        TargetType="{x:Type Button}" />
    <Style
        x:Key="{x:Static ToolBar.ToggleButtonStyleKey}"
        BasedOn="{StaticResource DxToolBarToggleButtonStyle}"
        TargetType="{x:Type ToggleButton}" />
    <Style
        x:Key="{x:Static ToolBar.SeparatorStyleKey}"
        BasedOn="{StaticResource DxToolBarSeparatorStyle}"
        TargetType="{x:Type Separator}" />

    <Style x:Key="DxToolBarTrayStyle" TargetType="{x:Type ToolBarTray}">
        <Setter Property="Background" Value="{DynamicResource DxSurfaceSubtleBrush}" />
        <Setter Property="IsLocked" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="DxToolBarStyle" TargetType="{x:Type ToolBar}">
        <Setter Property="Background" Value="{DynamicResource DxSurfaceSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource DxBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Foreground" Value="{DynamicResource DxTextBrush}" />
        <Setter Property="FontFamily" Value="{DynamicResource DxFontFamily}" />
        <Setter Property="FontSize" Value="{DynamicResource DxFontSize}" />
        <Setter Property="MinHeight" Value="{DynamicResource DxToolBarHeight}" />
        <Setter Property="Padding" Value="3" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style TargetType="{x:Type ToolBarTray}" BasedOn="{StaticResource DxToolBarTrayStyle}" />
    <Style TargetType="{x:Type ToolBar}" BasedOn="{StaticResource DxToolBarStyle}" />
</ResourceDictionary>
