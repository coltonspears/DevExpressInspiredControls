<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="DxGridSplitterStyle" TargetType="{x:Type GridSplitter}">
        <Setter Property="Background" Value="{DynamicResource DxBorderBrush}" />
        <Setter Property="FocusVisualStyle" Value="{DynamicResource DxFocusVisualStyle}" />
        <Setter Property="MinHeight" Value="{DynamicResource DxGridSplitterThickness}" />
        <Setter Property="MinWidth" Value="{DynamicResource DxGridSplitterThickness}" />
        <Setter Property="ShowsPreview" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type GridSplitter}">
                    <Border
                        x:Name="SplitterChrome"
                        Background="{TemplateBinding Background}"
                        SnapsToDevicePixels="True" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="SplitterChrome" Property="Background" Value="{DynamicResource DxAccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="SplitterChrome" Property="Background" Value="{DynamicResource DxAccentPressedBrush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="SplitterChrome" Property="Background" Value="{DynamicResource DxAccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="SplitterChrome" Property="Background" Value="{DynamicResource DxDisabledBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type GridSplitter}" BasedOn="{StaticResource DxGridSplitterStyle}" />
</ResourceDictionary>
