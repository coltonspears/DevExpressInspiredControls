<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:DevExpressInspiredControls.Controls">

    <Style TargetType="{x:Type controls:ToggleSwitch}">
        <Setter Property="Background" Value="{DynamicResource DxBorderStrongBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource DxTextBrush}" />
        <Setter Property="FontFamily" Value="{DynamicResource DxFontFamily}" />
        <Setter Property="FontSize" Value="{DynamicResource DxFontSize}" />
        <Setter Property="FocusVisualStyle" Value="{DynamicResource DxFocusVisualStyle}" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="MinHeight" Value="{DynamicResource DxControlHeight}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ToggleSwitch}">
                    <Grid Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border
                            x:Name="Track"
                            Width="36"
                            Height="20"
                            VerticalAlignment="Center"
                            Background="{TemplateBinding Background}"
                            CornerRadius="10">
                            <Ellipse
                                x:Name="Thumb"
                                Width="14"
                                Height="14"
                                Margin="3"
                                HorizontalAlignment="Left"
                                Fill="{DynamicResource DxSurfaceBrush}" />
                        </Border>
                        <ContentPresenter
                            x:Name="OffState"
                            Grid.Column="1"
                            Margin="7,0,0,0"
                            VerticalAlignment="Center"
                            Content="{TemplateBinding OffContent}" />
                        <ContentPresenter
                            x:Name="OnState"
                            Grid.Column="1"
                            Margin="7,0,0,0"
                            VerticalAlignment="Center"
                            Content="{TemplateBinding OnContent}"
                            Visibility="Collapsed" />
                        <ContentPresenter
                            Grid.Column="2"
                            Margin="10,0,0,0"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="Center"
                            ContentSource="Content"
                            RecognizesAccessKey="True" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Track" Property="Background" Value="{DynamicResource DxBorderBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background" Value="{DynamicResource DxAccentBrush}" />
                            <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                            <Setter TargetName="OffState" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="OnState" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Track" Property="Background" Value="{DynamicResource DxAccentHoverBrush}" />
                        </MultiTrigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource DxAccentPressedBrush}" />
                            <Setter TargetName="Track" Property="BorderThickness" Value="2" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Track" Property="Background" Value="{DynamicResource DxDisabledBrush}" />
                            <Setter TargetName="Thumb" Property="Fill" Value="{DynamicResource DxTextDisabledBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource DxTextDisabledBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
